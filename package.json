{
  "name": "ceo-magazine",
  "version": "3.28.2154",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "prebuild": "node scripts/vercel-preflight.js && node scripts/precompute-hero-aspects.js && node scripts/write-build-info.js",
    "build": "next build",
    "smoke": "node scripts/smoke-check.js",
    "test:e2e": "playwright test",
    "icons:gen": "node scripts/generate-favicons.js",
    "deploy:prod": "bash scripts/deploy-gated.sh",
    "start": "next start -p 3000",
    "lint": "eslint",
    "lint:content": "node scripts/lint-content.js",
    "fix:excerpts": "node scripts/fix-excerpts.js",
    "import:docx": "node scripts/import-docx-batch.js",
    "sanity:dev": "sanity dev -p 3333",
    "sanity:build": "sanity build",
    "sanity:deploy": "sanity deploy",
    "sanity:backup": "mkdir -p exports/backups && sanity dataset export production exports/backups/$(date +%F-%H%M)-production.tar.gz --yes",
    "sanity:restore": "sanity dataset import $BACKUP_FILE --dataset production --replace --missing --yes",
    "backfill-data": "tsx scripts/backfill-article-data.ts",
    "optimize:heroes": "node scripts/precompute-hero-aspects.js"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@portabletext/react": "^4.0.3",
    "@sanity/client": "^7.12.1",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^1.2.0",
    "@sanity/preview-url-secret": "^3.0.0",
    "@sanity/table": "^2.0.0",
    "@sanity/vision": "^4.18.0",
    "@sentry/nextjs": "^8.55.0",
    "@vercel/analytics": "^1.5.0",
    "dotenv": "^17.2.3",
    "mammoth": "^1.6.0",
    "next": "16.0.1",
    "next-sanity": "^11.6.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-player": "^2.16.0",
    "sanity": "^4.18.0",
    "styled-components": "^6.1.19",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@resvg/resvg-js": "^2.6.2",
    "@sanity/dashboard": "^5.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24.9.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.0.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
