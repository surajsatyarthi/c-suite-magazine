{
  "name": "ceo-magazine",
  "version": "3.28.2154",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "prebuild": "node scripts/validate-build-env.js && node scripts/vercel-preflight.js && node scripts/precompute-hero-aspects.js && node scripts/write-build-info.js",
    "build": "next build",
    "smoke": "node scripts/smoke-check.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "test:critical": "playwright test tests/e2e/category-page.spec.ts",
    "test:ci": "playwright test --reporter=github",
    "icons:gen": "node scripts/generate-favicons.js",
    "deploy:prod": "bash scripts/deploy-gated.sh",
    "start": "next start -p 3000",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint",
    "audit": "audit-ci --moderate",
    "secretlint": "secretlint \"**/*\"",
    "lint:security": "eslint -c eslint.security.config.mjs .",
    "lint:content": "node scripts/lint-content.js",
    "security-scan": "npx tsx scripts/ralph-verify-sql-safety.ts",
    "check:integrity": "npx tsx scripts/assumption-scanner.ts",
    "validate-reports": "bash scripts/validate-phase-report.sh",
    "fix:excerpts": "node scripts/fix-excerpts.js",
    "import:docx": "node scripts/import-docx-batch.js",
    "sanity:dev": "sanity dev -p 3333",
    "sanity:build": "sanity build",
    "sanity:deploy": "sanity deploy",
    "sanity:backup": "mkdir -p exports/backups && sanity dataset export production exports/backups/$(date +%F-%H%M)-production.tar.gz --yes",
    "sanity:restore": "sanity dataset import $BACKUP_FILE --dataset production --replace --missing --yes",
    "backfill-data": "tsx scripts/backfill-article-data.ts",
    "optimize:heroes": "node scripts/precompute-hero-aspects.js",
    "prepare": "husky && husky install"
  },
  "engines": {
    "node": "22.x"
  },
  "packageManager": "pnpm@10.20.0",
  "dependencies": {
    "@google-analytics/data": "^5.2.1",
    "@portabletext/react": "^4.0.3",
    "@sanity/client": "^7.14.0",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^1.2.0",
    "@sanity/preview-url-secret": "^3.0.0",
    "@sanity/table": "^2.0.1",
    "@sanity/ui": "^3.1.11",
    "@sanity/vision": "^4.22.0",
    "@sentry/nextjs": "^8.55.0",
    "@vercel/analytics": "^1.5.0",
    "@vercel/postgres": "^0.10.0",
    "dotenv": "^17.2.3",
    "mammoth": "^1.6.0",
    "next": "16.1.0",
    "next-sanity": "^11.6.5",
    "nodemailer": "^7.0.11",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-player": "^2.16.0",
    "rxjs": "^7.8.2",
    "sanity": "^4.22.0",
    "server-only": "^0.0.1",
    "styled-components": "^6.1.19",
    "turndown": "^7.2.0",
    "zustand": "^5.0.9"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint -c eslint.security.config.mjs",
      "secretlint"
    ],
    "*": [
      "secretlint"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@playwright/test": "^1.56.1",
    "@resvg/resvg-js": "^2.6.2",
    "@sanity/dashboard": "^5.0.1",
    "@sanity/export": "^6.0.5",
    "@secretlint/node": "^11.3.0",
    "@secretlint/secretlint-rule-aws": "^11.3.0",
    "@secretlint/secretlint-rule-preset-recommend": "^11.3.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.9.2",
    "@types/nodemailer": "^7.0.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitest/coverage-v8": "^4.0.17",
    "audit-ci": "^7.1.0",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.0.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "google-auth-library": "^10.5.0",
    "googleapis": "^170.1.0",
    "husky": "^8.0.0",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "png-to-ico": "^3.0.1",
    "qs": "^6.14.1",
    "secretlint": "^11.3.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.17"
  },
  "pnpm": {
    "overrides": {
      "lodash": ">=4.17.23",
      "lodash-es": ">=4.17.23",
      "undici": ">=6.23.0"
    }
  }
}
