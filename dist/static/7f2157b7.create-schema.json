      {
        "options": {
          "list": [
            {
              "title": "Article Sidebar (300x250)",
              "value": "article-sidebar"
            },
            {
              "title": "Article Sidebar Large (300x600)",
              "value": "article-sidebar-large"
            },
            {
              "title": "In-Article (728x90 Leaderboard)",
              "value": "in-article"
            },
            {
