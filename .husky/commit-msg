#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# 🛡️ Ralph Protocol v2.5: Semantic Commit Enforcement
# Enforces an issue-anchored security checklist.

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Pattern: SECURITY-CHECKLIST [#IssueID]: [x]
# Matches: SECURITY-CHECKLIST [#06]: [x] ...
CHECKLIST_PATTERN="SECURITY-CHECKLIST \[#[0-9]+(, [0-9]+)*\]: \[[x ]\]"

if ! grep -qE "$CHECKLIST_PATTERN" "$COMMIT_MSG_FILE"; then
  echo ""
  echo "❌ Ralph Protocol v2.5 Failure: Missing or Malformed Security Checklist."
  echo "------------------------------------------------------------------------"
  echo "Your commit message must include a checklist anchored to the Issue ID."
  echo "Example:"
  echo "  SECURITY-CHECKLIST [#06]: [x] No injection risk [x] Revenue intact [x] Air-Gap used"
  echo ""
  echo "Current Message:"
  echo "$COMMIT_MSG"
  echo "------------------------------------------------------------------------"
  exit 1
fi

echo "✅ Semantic Security Checklist Verified."
