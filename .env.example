# Example environment variables for local development and CI build checks
# Replace values with real secrets in Vercel / deployment provider

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=demo
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
SANITY_WRITE_TOKEN=
SANITY_API_TOKEN=
SANITY_AUTH_TOKEN=
SANITY_PROJECT_ID=

# Site verification (optional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
NEXT_PUBLIC_YANDEX_SITE_VERIFICATION=

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=
GA4_PROPERTY_ID=

# Email Configuration (for SEO reports)
EMAIL_USER=
EMAIL_PASS=
EMAIL_TO=

# Google Drive Backup (for GitHub Actions)
GDRIVE_FOLDER_ID=
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_REFRESH_TOKEN=

# Ad Configuration
NEXT_PUBLIC_FALLBACK_AD_ID=

# Feature flags / small public values
NEXT_PUBLIC_SPOTLIGHT_COUNT=5
NEXT_PUBLIC_ENABLE_INSIGHTS=0

# Other
BASE_URL=http://localhost:3000
SLACK_WEBHOOK_URL=
VERCEL_WEBHOOK_SECRET=

# Note: Keep real secret tokens in your deployment provider (Vercel), not in this file.
