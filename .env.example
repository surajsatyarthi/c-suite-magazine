# Sanity Configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=2f93fcy8
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
NEXT_PUBLIC_SANITY_STUDIO_HOST=ceo-magazine-2f93fcy8

# Sanity Tokens (Server-Side Only)
# sk... (Copy from Sanity Manage -> API -> Tokens)
